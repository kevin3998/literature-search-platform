# Local development defaults. Copy to `.env` and adjust paths as needed.

POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://literature_agent:literature_agent_dev@127.0.0.1:5432/literature_agent
DB_SCHEMA=literature_agent

APP_ENV=development
AUTH_MODE=dev-header

# Formal local login (uncomment for browser email/password auth):
# AUTH_MODE=local-password
# ENABLE_SIGNUP=true
# SESSION_TTL_DAYS=30
# PASSWORD_MIN_LENGTH=8
# COOKIE_NAME=lap_session
# CSRF_COOKIE_NAME=lap_csrf
# COOKIE_SECURE=false

LITERATURE_RESEARCH_CODE_DIR=/Users/chenlintao/paper-crawler-ops/literature_research
LITERATURE_DATA_DIR=/Users/chenlintao/paper-crawler-ops/literature_data
LIBRARY_DIR=/Users/chenlintao/paper-crawler-ops/literature_data
LITERATURE_USER_DATA_ROOT=.runtime/users
LITERATURE_SECRET_KEY_PATH=.runtime/secret.key

WORKER_QUEUES=default,workflow,structured-extraction
START_WORKER=1

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
